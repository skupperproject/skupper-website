        <!--     <li>{{lipsum(6)}}</li> -->
        <!--     <li>{{lipsum(6)}}</li> -->
        <!--   </ul> -->
        <!-- </div> -->

        <p style="font-family: 'Alegreya Sans'; font-size: 1.6em;
          font-weight: 400; line-height: 1.6em;"><b>Skupper</b> is a
          multi-platform service interconnect.  It enables you to
          create private application networks that span Kubernetes
          clusters, containers, VMs, and bare-metal hosts.</p>

        <p>
        <nav id="-main-links" style="clear: left;">
          <a href="start/index.html">Getting started</a>
          <a href="install/index.html">Installation</a>
          <a href="examples/index.html">Examples</a>
          <a href="concepts/index.html">Concepts</a>
          <a href="resources/index.html">YAML</a>
          <a href="commands/index.html">CLI</a>
          <a href="docs/index.html">Documentation</a>
          <a href="community/index.html">Community</a>
          <a href="v1/index.html">Skupper v1</a>
        </nav>
        </p>
      </div>
    </section>
    <section>
      <div style="display: flex; justify-content: center;">
        <div>
        </div>
      </div>
    </section>
    <section>
      <div>
        <h2>Platforms, connectivity scenarios, and use cases</h2>
      </div>
    </section>
    <section id="-cli">
      <div>
        <h2>The Skupper CLI</h2>

        <h4>Install the Skupper CLI</h4>

        <div><pre><code>curl https://skupper.io/install.sh | sh</code></pre></div>

        <h4>Install Skupper on Kubernetes</h4>

        <div><pre><code>kubectl -f https://skupper.io/install.yaml</code></pre></div>

        <h4>Create sites, link sites, and expose services</h4>

        <div class="side-by-side">
          <pre><code>{{page.include("include/west.sh")}}</code></pre>
          <pre><code>{{page.include("include/east.sh")}}</code></pre>
        </div>
      </div>
    </section>
    <section id="-kubernetes">
      <div>
        <h2>Skupper YAML</h2>

        <h4>Install Skupper on Kubernetes</h4>

        <div><pre><code>kubectl -f https://skupper.io/install.yaml</code></pre></div>

        <h4>Create sites, link sites, and expose services</h4>

        <div class="side-by-side">
          <pre><code>{{page.include("include/west.yaml")}}</code></pre>
          <pre><code>{{page.include("include/east.yaml")}}</code></pre>
        </div>
      </div>
    </section>
