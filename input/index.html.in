---
title: Skupper
body_template: null
---

<style>

  body.front {
      /* A simplification of the standard page structure */
      grid-template-areas:
          "header header header header"
          "main main main main"
          "footer footer footer footer";
  }

  body.front > header {
      border: none;
  }

  body.front > main {
      display: flex;
      flex-direction: column;
      padding: 0;
  }

  body.front > main > section {
      display: flex;
      justify-content: center;
      margin: 0;
      border-bottom: 3px solid var(--line-color);
  }

  body.front > main > section > div {
      width: var(--page-width);
      padding: 2em 1em;
  }

  header,
  header a,
  #-lead,
  #-lead a {
      background-color: #5eba7d;
      color: white !important;
  }

  #-lead > div {
      padding-top: 1em;
  }

  #-main-links {
      display: flex;
      gap: 1em;
      flex-wrap: wrap;
      font-size: 0.95em;
  }

  #-main-links > a {
      display: block;
      border-radius: 0.5em;
      background-color: hsl(140, 40%, 40%);
      padding: 1em;
      font-weight: 600;
  }

</style>

<body class="front">
  <header>
    <div>
      <a href="{{site.prefix}}/index.html" id="-logotype">
        <img src="{{site.prefix}}/images/skupper-logo.svg">
      </a>

      {{page.path_nav()}}

      <a href="https://github.com/skupperproject">
        <div><span class="fab fa-github fa-lg"></span> GitHub</div>
      </a>
    </div>
  </header>
  <main>
    <section id="-lead">
      <div>
        <h1 style="font-size: 2.5em; line-height: 1em;">Multicloud cross-platform networking for your application</h1>

        <iframe style="width: 17.8em; height: 10em; margin: 0 2em 2em 0; float: left;" src="https://www.youtube.com/embed/pm8OP9bG2mU" frameborder="0" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen="allowfullscreen"></iframe>

        <!-- <div style="width: 300px; margin-left: 4em; float: right;"> -->
        <!--   <ul> -->
        <!--     <li>{{lipsum(6)}}</li> -->
        <!--     <li>{{lipsum(6)}}</li> -->
        <!--     <li>{{lipsum(6)}}</li> -->
